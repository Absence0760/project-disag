project          = "disag-md"
bootstrap_slug   = "disag"          # must match the slug used when running new-project-account.sh
environment      = "prod"           # "dev" / "staging" / "prod" — drives resource names and the resolved fqdn
region           = "us-east-1"

# Required: the delegated Route 53 hosted zone for this project,
# matching the one the bootstrap baseline created. Prod CloudFront
# serves at this exact fqdn; non-prod environments serve at
# "<env>.<parent_domain>".
parent_domain    = "project.example.com"

# Compute-bound disag runs benefit from more CPU; bump to 8192 or 10240
# for large monthly files with Method 5 (PATCH_EXCEED). New AWS accounts
# cap at 3008 — request a Service Quotas increase before going higher.
# API Gateway HTTP API hard-caps integration timeouts at 30s — anything
# higher is rejected at apply time. The Lambda itself can run longer, but
# the caller sees a 504 from API GW at the 30s mark while the function
# keeps billing. Keep timeout ≤ 29.
lambda_memory_mb       = 3008
lambda_timeout_seconds = 29

# CORS allow-origin. Prod refuses to apply unless this is a concrete
# https:// URL (validation in variables.tf). In dev/staging "*" is fine.
allowed_origin = "https://project.example.com"

# Wallet-bleed defences. Defaults in variables.tf are reasonable;
# uncomment any line below only when you want to override.
# budget_monthly_usd    = 50
# budget_alert_email    = "you@example.com"
# waf_rate_limit_per_ip = 500
# max_upload_bytes      = 10485760  # 10 MiB
# upload_ttl_seconds    = 300
# download_ttl_seconds  = 600
