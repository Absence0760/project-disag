# Shape of web/infra/secrets.enc.yaml. Copy to secrets.enc.yaml, fill
# in the real values, then encrypt:
#
#   cp web/infra/secrets.enc.yaml.example web/infra/secrets.enc.yaml
#   sops -e -i web/infra/secrets.enc.yaml
#
# Edit in place later with `sops web/infra/secrets.enc.yaml` — sops
# decrypts to a temp file, opens $EDITOR, re-encrypts on save.
#
# Wire into Terraform once a real secret lands:
#
#   data "sops_file" "secrets" {
#     source_file = "secrets.enc.yaml"
#   }
#
#   resource "aws_apigatewayv2_api" "http" {
#     ...
#     cors_configuration {
#       allow_origins = [data.sops_file.secrets.data["allowed_origin_prod"]]
#     }
#   }
#
# Nothing here today is actually sensitive — every value in
# variables.tf is public knowledge. This file exists so the workflow
# is ready when something private (an ACM cert ARN, a private origin,
# a third-party API key) needs to land in infra.
data:
  allowed_origin_prod: https://example.cloudfront.net
  # custom_domain_cert_arn: arn:aws:acm:us-east-1:123:certificate/...
  # third_party_api_key: dummy-replace-me
