# Override the API base path. Empty means use the default `/api`,
# which works both in dev (via the Vite proxy in vite.config.ts) and
# in prod (via CloudFront's /api/* behaviour).
#
# Set to a full URL only when you need to bypass the proxy — e.g.
# pointing the dev frontend at a deployed API Gateway directly:
#   VITE_API_BASE=https://abc123.execute-api.us-east-1.amazonaws.com
VITE_API_BASE=
