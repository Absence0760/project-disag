# Prod secrets and their sops config live in the private ../infra-secrets
# repo, NOT here (this repo is public). Nothing sops-related is tracked in
# this repo; guard against an accidental copy landing in the tree.
.sops.yaml
secrets.enc.yaml
web/infra/secrets.enc.yaml
web/infra/secrets.yaml
web/infra/secrets.json